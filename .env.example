# ===========================================
# PROPER MKT - Credenciales
# ===========================================
# Copiar este archivo como .env y llenar los valores
# cp .env.example .env
# ===========================================

# Gemini API (obligatorio)
GEMINI_API_KEY=tu-api-key-aqui

# PostgreSQL (Railway proporciona esto automaticamente)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Flask
PORT=5000
FLASK_DEBUG=false

# Scheduler (hora en formato 24h)
SCHEDULER_HOUR=7
SCHEDULER_MINUTE=0

# yt-dlp path (dejar vacio para usar el del PATH)
# YT_DLP_PATH=/usr/local/bin/yt-dlp
